<?xml version="1.0" encoding="utf-8"?>
<!-- Android TV Banner 320x180dp — shown in TV launcher -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0f172a"/>
        </shape>
    </item>
    <!-- Gradient overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1e40af"
                android:endColor="#0f172a"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>
    <!-- App name text via padding -->
    <item android:top="60dp" android:left="20dp" android:right="20dp" android:bottom="60dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <stroke android:width="2dp" android:color="#3b82f6"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</layer-list>
